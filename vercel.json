{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.andreas-hagl.de" }],
      "destination": "https://andreas-hagl.de/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "beratung-hagl.de" }],
      "destination": "https://andreas-hagl.de/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.beratung-hagl.de" }],
      "destination": "https://andreas-hagl.de/:path*",
      "permanent": true
    }
  ]
}
